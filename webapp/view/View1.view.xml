<mvc:View controllerName="helloui5.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
    <Page id="page" title="{i18n>salesTitle}" showHeader="true">
        
        <!-- <Text text="Hello from SAP UI5!" />
        <Button text="Click me" press=".onButtonPress" /> -->

        <headerContent>
            <Button text="Edit" press=".onEditPress"></Button>
        </headerContent>

        <f:SimpleForm xmlns:f="sap.ui.layout.form" editable="false" layout="ResponsiveGridLayout" title="Order Information">

        <f:content>

        <Label text="Order Number" />
        <Text text="{/orderNumber}" />

        <Label text="Customer" />
        <Text text="{/customer}" />

        <Label text="Status" />
        <Text text="{/status}" />

        <Label text="Net Value" />
        <Text text="{/netValue} {/currency}" />

        </f:content>

        </f:SimpleForm>
    </Page>
</mvc:View>